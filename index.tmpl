<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><!-- TITLE --></title>
<style>
    body {
        font-family: Arial, sans-serif;
        margin: 20px;
    }
    h1 {
        /* color: #333; */
        margin-top: 0px;
        margin-bottom: 15px;
    }
    h2 {
        /* color: #333; */
        margin-top: 0px;
        margin-bottom: 15px;
    }
    ul {
        list-style-type: none;
        padding-left: 0;
    }
    li {
        margin: 10px 0;
    }
    a {
        text-decoration: none;
        color: #007BFF;
    }
    a:hover {
        text-decoration: underline;
    }
</style>

<script>

let images = [ <!-- IMAGES_JSON --> ];
let currentIndex = 0;
let isPaused = false;
let isSlideshowEnabled = localStorage.getItem('slideshowEnabled') !== 'false';

function showImg(filename, notes) {
    const image = document.getElementById('img');
    image.src = filename;
    const img_link = document.getElementById('img_link');
    img_link.href = filename;
    const captionElement = document.getElementById('caption');
    if ( notes ) {
        captionElement.textContent = filename + ': ' + notes;
    }
    else {
        captionElement.textContent = filename;
    }
}

function toggleSlideshow() {
    isSlideshowEnabled = !isSlideshowEnabled;
    localStorage.setItem('slideshowEnabled', isSlideshowEnabled);
    updateSlideshowUI();
}

function updateSlideshowUI() {
    const cb = document.getElementById('slideshow_toggle');
    if (cb) {
        cb.checked = isSlideshowEnabled;
    }
}

function startSlideshow() {
    updateSlideshowUI();
    if (images.length <= 1) {
        const ctrl = document.getElementById('slideshow_control');
        if (ctrl) ctrl.style.display = 'none';
        return;
    }
    
    setInterval(() => {
        if (!isSlideshowEnabled || isPaused) return;
        currentIndex = (currentIndex + 1) % images.length;
        const nextImg = images[currentIndex];
        const imgElement = document.getElementById('img');
        const imgLink = document.getElementById('img_link');
        const captionElement = document.getElementById('caption');

        // Simple fade effect using opacity
        imgElement.style.transition = 'opacity 1s ease-in-out';
        imgElement.style.opacity = 0;

        setTimeout(() => {
            imgElement.src = nextImg.filename;
            imgLink.href = nextImg.filename;
            captionElement.textContent = nextImg.caption;
            imgElement.style.opacity = 1;
        }, 1000);
    }, 30000); // 30 seconds
}

window.onload = startSlideshow;

</script>

</head>
<body>

<div style="float: right; width: 50%; text-align: right;" onmouseenter="isPaused = true" onmouseleave="isPaused = false">
    <figure id="random_img" style="text-align: center;">
    <a id="img_link" target="_blank" href="<!-- RANDOM_IMAGE -->"><img id="img" src="<!-- RANDOM_IMAGE -->" style="max-width: 100%; opacity: 1;"></a><br>
    <figcaption id="caption"><!-- RANDOM_IMAGE_CAPTION --></figcaption>
    </figure>
</div>
<div style="float: left; width: 50%;">

    <h1><!-- ARCHIVE_HEADER --></h1>
    <h2><!-- TITLE --> <!-- COUNT --> <!-- TOTAL --></h2>
    <div id="slideshow_control" style="margin-bottom: 10px; font-size: 0.9em; color: #666;">
        <input type="checkbox" id="slideshow_toggle" onClick="toggleSlideshow();" style="vertical-align: middle; cursor: pointer;"> <label for="slideshow_toggle">Slideshow</label>
    </div>
    <h3>last generated <!-- DATETIME --></h3>
    <!-- SUBDIR -->

    <div style="height: 80vh; overflow-y: auto; border: 1px solid #ccc; padding: 8px;">
        <ul>
            <!-- SUBDIRS -->
        </ul>

        <ul>
            <!-- CONTENT -->
        </ul>
    </div>



</div>
<div style="clear: both;"></div>


</body>
</html>
